// Staging Dir is where the large dataframes are
params.stagingDir = "/pipeline42/datasets/AlexA"

//// Executor Settings
executor {
    name = 'local'
    queueSize = 32
    pollInterval = '30 sec'
    cpus = 32
    memory = '400 GB'
}

conda {
    enabled = true
    useMamba = true
}

