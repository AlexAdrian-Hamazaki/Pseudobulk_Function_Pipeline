params.tissue_dir = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/preprocessing/preprocessSC_pipe/data/h5ad_datasets/processed/cpm/brain_sc_with_metadata_pc_cpm.h5ad"


// The compositional variance, a list of floats.
params.compositional_variance = [0.05, 0.1, 0.5, 1]

// Params for performance on simulated GO terms
//params.go_annotations = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/analysis/PaperFigs/SimulatedBulk/sim_functions_sim_data/excitatory_neurons/data/excitatory_neuron_GOs.csv"
//params.gene_column = "ensembl_gene_id"

// Params for performance on BP GO terms
params.go_annotations = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/preprocessing/preprocessGO_pipe/data/2024/data/final/bp_annotations_withGeneData_qc_annotations_no_dependance.csv"
params.gene_column = "ensembl_gene_id"

// The initial percent composition
// params.cell_type_proportions = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/getBaselineProps/cell_type_proportions2.json"
// params.cell_type_proportions = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/EGADSimulatedGOTerms/cell_type_proportions_noexi.json"
params.cell_type_proportions = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/EGADSimulatedGOTerms/cell_type_proportions.json"




// how many bulk samples will be in each dataset
params.num_sims = 100

// Path to GO CTAffiliation information
params.ctaffiliation_csv = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/preprocessing/preprocessGO_pipe/ontologyPropagation/BPcuratedAllRegex.csv"

//Bulk GO Performance for BP
params.bulk_performance = "/space/grp/aadrian/Pseudobulk_Function_Pipeline_HighRes/bin/bulkEGADPipeline/data/splitOPs1/EGAD/{Blood,Brain}_split.csv_bp_annotations_withGeneData_EGAD.csv"

// How many times to bootstrap aka how many times we will do the whole pipeline of simulating bulk and training
params.num_bootstrap = 50

// workDir is where the work directories are run and stored
workDir = "/scratch/aadrian/GOsims/work"


// Publish Dir base path
params.publish = "data/real_go_feb2026_allcells/"

// Staging Dir is where the large dataframes are
params.stagingDir = "/pipeline42/datasets/AlexA"


//// Executor Settings
executor {
    name = 'local'
    queueSize = 32
    pollInterval = '30 sec'
    cpus = 32
    memory = '400 GB'
}
// Conda Environments

conda {
    enabled = true
    useMamba = true
}

params.python3_9 = "/home/aadrian/miniforge3/envs/main_env"